# q27 RunPod Serverless image -- BUILD FROM SOURCE (recommended default).
#
# Why source, not the prebuilt release tarball: the v0.3.1 binaries link
# the CUDA 13.2 runtime and need host driver r580+. RunPod serverless
# hosts are not guaranteed that new. Building against 12.8 here lowers the
# floor to r570+ (covers essentially every current RunPod GPU host).
# If you have CONFIRMED your worker pool runs r580+, use ./Dockerfile
# (prebuilt) instead for a smaller image and faster build.
#
# Weights are NOT baked in -- attach a RunPod network volume with the
# .q27 + .tok and point Q27_MODEL / Q27_TOK at /runpod-volume/... (see README).

FROM nvidia/cuda:12.8.0-devel-ubuntu24.04 AS build
RUN apt-get update && apt-get install -y --no-install-recommends git g++ make ca-certificates \
    && rm -rf /var/lib/apt/lists/*
ARG Q27_REF=v0.3.1
RUN git clone --depth 1 --branch ${Q27_REF} https://github.com/signalnine/q27 /src
WORKDIR /src
# sm_86 (A5000/A6000) + sm_89 (4090/L40/L40S) cover the 24-48GB serverless
# cards a 27B model wants. Add compute_120 if you deploy on 5090-class.
RUN make NVCC=/usr/local/cuda-12.8/bin/nvcc \
    NVCCFLAGS="-O2 -std=c++17 -gencode arch=compute_86,code=sm_86 -gencode arch=compute_89,code=sm_89 -Xcompiler -Wall" \
    build/q27-server-w8

FROM nvidia/cuda:12.8.0-runtime-ubuntu24.04
RUN apt-get update && apt-get install -y --no-install-recommends python3 python3-pip curl ca-certificates \
    && rm -rf /var/lib/apt/lists/*
RUN pip3 install --no-cache-dir --break-system-packages runpod
COPY --from=build /src/build/q27-server-w8 /opt/q27/q27-server-w8
COPY handler.py /handler.py
ENV Q27_BIN=/opt/q27/q27-server-w8 \
    Q27_MODEL=/runpod-volume/qwen36-27b-mtp-q4s.q27 \
    Q27_TOK=/runpod-volume/qwen36-27b-mtp.tok \
    Q27_KV=turbo3
# Q27_KV=turbo3 default = full 262K window on a 24GB card. Set Q27_KV=fp8
# for max single-stream speed at less context, or unset on sm_86 (turbo3
# is the sm_86 default). For greedy-only serving add Q27_SAMPLED=0 to
# skip ~600MB of sampled graphs and shorten cold boot.
CMD ["python3", "-u", "/handler.py"]
